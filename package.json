{
	"name": "hardhat-external-artifacts",
	"version": "0.0.0",
	"description": "Hardhat plugin that allow hardhat to know about them",
	"keywords": [
		"hardhat",
		"ethereum",
		"solidity"
	],
	"author": "Ronan Sandford",
	"license": "MIT",
	"homepage": "https://github.com/wighawag/hardhat-external-artifacts#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wighawag/hardhat-external-artifacts.git"
	},
	"bugs": {
		"url": "https://github.com/wighawag/hardhat-external-artifacts/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"main": "dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"files": [
		"dist",
		"src"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"@rocketh/node": "^0.19.3",
		"@types/node": "^25.2.3",
		"as-soon": "^0.1.5",
		"hardhat": "3.1.8",
		"rimraf": "^6.1.3",
		"set-defaults": "^0.0.5",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"hardhat": "^3.1.8"
	},
	"dependencies": {
		"@nomicfoundation/hardhat-utils": "^4.0.0",
		"viem": "^2.0.0"
	},
	"scripts": {
		"prepare": "pnpm build",
		"build": "tsc --project tsconfig.json",
		"dev": "as-soon -w src pnpm build"
	}
}
